&&&&&&&&&&''&&&''&&''&&%%$$#######""!!`└АЖ└`!!!!!""##$$%%%&&'''&''(())**))((''&&%%$$##""!!`▐└ЛЙКНРОПСПСФТЦУУФОЛОЦНВАД╥``╙КМТСОЖАААБАААВЙЕВВДЕАИМЖАААААГКААБЛСРХФУФФЧШЪЮЩПСССХХХШЫЫШШЦЧШХТЖКЖААКЬЮЮЮШУШХУРМККПХРГААААААААААГИЕЕЙЖЖИБАААВААБГАААААДЧЬЮЮЬЧШТШЩЩШОЛЙКМ─`!!!""###$$$$$%%%&&&&&'''(())**++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++**))((''&&%%$$##""!!`╘ФФФСОЛДИТШУСФРХУСТНЖПРЖБИЗЕЖГГБ└`!!""##$$%%&&''(())****))((''&&%%$$##""!!`┬ИККЗЛЛОСПХТТЦОИЕЗПНЕАААШМОЩУЪЮЮЭЪФРРЛЙПМОАЮЮЮЮЮАГААВГГЛПКЕЗААГД└`!!""##$$%%%$$##""!!`╩ГДЕЕАААААВЖЛЖАДАДААЛЫЖРРЕУХЙДПМПЛПДААААДДААВГЖЗЛЙБАЛКЗЕЖКЦ▐`!`▌ЮЪКЙЛКИРХТСМРШНУЦЪРЕЮЮЮЮЮЮЮЮЮДШОПРЪФАЖЙЙИЖГАААГАААБАААЮЮЮЮЮЮЮЮМШЭЮЮЮЫЫППШЮЮЮЮЮЮЮЮЮЮЮЪЮЬЭЬУФЬЫЬТСУ╓`!!""##$$%%&&''(())**++++++++++++++**))((''&&%%$$###""!!`└╒ЮШНМОДЙЛПХШЩЪЬСТФПСНРЛИЙКОМЕДЖГЕИИЗЙЗЙИЕГЙММЕГВЕРТ└`!!""##$$%%&&''(())****))((''&&%%%%%%&&&&&&&&&&&&&&&&%%$$###""##""!!`└ААБА┴````!!""##$$%%%&&'&&&''(())**))((''&&%%$$##""!!``╞ЙИЛСНЕККОКПТРЦРЛЙУПЕАААЮ▐▐ЧАПЖЗБААААГАГГЕЖДЖВБЖАЕКИАААААВГВАГЗМПХЫШНОТЧЪЧТТТРТХФЦФЬЭЧЦФХФХЧГЛЗЗЕЗЛЮЮЮЮЩЭЪЦХХЧФТШЫЩЬЧСДААААААААЗКЖБВГБААААААБГААААВХЩПЦЩЪЬХТХЦЪЪЙМЗЙ╔`!!"""###$$$$%%%%&&&&''''(())**++++++++++++++++++++++++++++++++++++++++++++**++++++++++++++++++++++++++++++++++++++++++++++++++**))((''&&%%$$##""!!`╙РЧТЪСДДНХФТРПРОПУЦОУПДВИЖЖМЕДГА╬`!!""##$$%%&&''(())****))((''&&%%$$##""!!`╠ИГДЖРСРУЪСРОЗГДЛЛЕААЮАОНЩЮЮЫЪЩШФМНЙЙЛХРВААОЧЫШЮЮЮЪИГЛИНПЙДААДГ└`!!""##$$%%%$$##""!!`╩ЗЕВДАААААВЖИАААААААРЭНССИЛУПВКЕЛЙЛТСМЗАЗЖАВААААВЛТЗИЛКЕГАЩШ└``▐ЮААЙКМЛСЪУТСПШОЦШЩЫЧААЮЮЮЮГЮЮЮЮМИКЦОААГДГЖЕААААБВВБААЮЮЮЮЮЮЮЮКЮШЬЮЮЮЮЮЮЮЪЮЮЮЭЬЮЮЬЪЮЮЮЭЪШЮНЩЮЩЩФТП╦`!!""##$$%%&&''(())**+++++++++++++**))((''&&%%$$##"""!!`└ЬЫЮЮЪЧИВЛФЬЪЦЫЪХХФЦСОКОНННМППЕАБВДЕЗДКЗЗЕДЙМОКДГГПРПО└`!!""##$$%%&&''(())****))((''&&%%%%%%%%%%%&&%%%&&%%&&%%$$##"""""""!!`└ААААБА└└└└`!!""##$$$%%&&&%&&''(())))((''&&%%$$##""!!``└ВЕИКПОМКЛРСРЦУТМЙКХЕАБЗАЮЮЮИАДАААААААВБЖЖИББИДЕДЗАВЙААААБДБААВБДМНПОЛРШЫЮХМПРСРПХТХЪЪЩШХУФХЫНЛЮЮЭЪШЭЮЪЬШЦЭЮЮЬЮЮЮЫЮЮЮЮЮЮЫОДЖЖББАДОИБАААААААААВААААЖЧЧФУЛШЮЫЬЩТЪЬНЗЕК╠`!!