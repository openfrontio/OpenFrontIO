++++++**))((''&&%%$$##""!!`▐ЫААААЛЦЪЧЙМЛАТУЩЧЩЬЮЩЬЪЧЮЫШЪУФУПЙТСЙИПТУЦФЦЧФТХХППНДБЕКАБЙБГКНЙБЕРММААЖЗВАЗСЛДОТЖАААГВЕДКМЗНОМЛОРТРИЗЛЛЗЖИИЗЖИЗЛЛИЗЙЙДЗНЛНХТПНКЖДГВВЙПДАААААААААААБАААВДЖИЙИКЗЕЗКПСТЙГГКЖВЗЛДВЙНКЕИДГИЖАААААААААААРЮЮЙАБКАА└````!!""##$$%%&&''(())****))((''&&%%%%$$$$$$#$###"""!!!`!!!!"""""""!!!!!!!`└ГЖАОСРЦЦПЩЫШХТЧЧХТШЩХЦФУТНЛЙЗЗЕЙЙЛЛЛМЛПФУФЦХСОМХФЧЦУУУФТУФФОНТОРНОНММНПСМКЗБААААААААААА└`!!""####"""!!!!`▐ЕЕЖИОЕВВДЗШЫЮЮФЧЬЫФААЕСААДЗААВЖЖИЮЮТАИЦЮДДЕЙКУЩХТЕЫДАПЦАР┬`!!"""!!`═ГААААААВИНЖААБИДАВЛЖААГАААААААГДЖКНООСССТОЛИЛПРТЛЙУХУУРМИАААП╘▌`!!""##$$%%&&''(())**++++++++++++++++++++++++++++++++++++++++**))((''&&%%$$##""!!`╥АИ▐РБСФРЖЙКЛЩУУТОСЪЭЮФЬЮЮЦХПХРММСЖДИУШШУПНТХЩЭППФИВДДВВЙЗААВИВДНФУЕААДКААВЦППТУЧОААГИВЕЛНРНППММФНМОМХТННОУНМНРРЛИЙЗЗЕЖНПОФПОИНКРЧЖКЖЖНААКЙГГААААААИЗЙЙИЕЖЖДИЙДБАИАБГНАКМДДМГБОНЖЕЗЙЙААВЗВВАБААААААБНЙСИШВА┬`!!!!""##$$%%&&''(())****))((''&&%%%%%%%$$$$$$###""!!!!""""""""""""""!!`▐▐МЗКЗЛПСУРЧЭЪЩЦЪЬХФХХФЦТТФПНМЙЙИКРПУООУТЧЦФФТНКПХЦХХХСХЫЩЩЩХТТПМЛКНРОРТСТОЗДЕДААБАААААААА└`!!""####"""!!!`┬УАЖИЗЗБНМАФУЛУЫКДНЖАГШЩАЛЫИГЙПЙПМЮСФИЙЦЩУЦРАХЪТЖЖЗТАААЮЩЩ╬`!!""""!!`╟АААААААЖЕДДАИГААВБАААААААААААЗЕЗПУСРРУРОПРСХСФМЙХЩРГЛМЛПТЩУ╥``!!""##$$%%&&''(())**+++++++++++++++++++++++++++++++++++++++++**))((''&&%%$$##""!!`▐А▐`█ГЖЗЗВБВОСККЛМКРЛКОФЧУСФПРПЛНОГИКРФООМКРЦЭЮТХКАЖЕЙДАИАААВЗИОЛМТААААВАААРТППЫЫЧЛААЛМДЕДЙЛУТРМОЗЕЙОТРЛПНЛИЕЗЙЙЙКЛИКМЛЙЙНСЗЛМЙКЕФТМИАИЛЗГЕААААЕЖБДГИКИКЗЕЗЗИЗЙЗААААААГЕАЕДВИДГДГРЗЕМЖГЖИЕДВДЖБААААААААКОМИ╠`!!!""##$$%%&&''(())****))((''&&&&%%%%%%$%$$$###"""!""""#######"""""!!``█ЪОКНРОПОЕНЬЮЫШОЦЦХЩШЧЧФХУПКЖИКЛРРТСФТУФРНХССРХФУУХЦШЩЮХЪЧЦПОМСТРССППРОМЛЗЕЗЗВАВГБААААААВ└`!!""#####"""!!`╤НЕЖАДГМИААВАЛГАААМАШЮСНЮЮЮЭЮТФЮЮ█▐▐ЮЮЩЬЮХОВАТБАААААГЮЮЮЖ─`!!""""!!`├ВАААААГЖЕЖДЕИЕАДАВБАААААААААГЗДЙФТРРХПНХХХТЦИПЙУЪОУОТХЛЗФШЮЮ╥`!!""##$$%%&&''(())**+++++++++++++++++++++++++++++++++++++++++**))((''&&%%$$##""!!`▐▐▐``└АБГБЕИНИИЖКИЙЛЗГЖЕДАААААГЕКЛИМКОЙЙЖМОУРХЦСОБКЛЖЕГДДААДВЗКМОИЕААААААААРУПКШЮХЭУАЕМКДДЕЙЗИИНПУТЙГЗНЛКНМКЖЕВБЕЛКЛННМЙЗМОМЖРОЦПАЖСМАБАААААААДЗЖААГЙЗЗЙЖЗЕИЙЖИМВАААААГЙЕАААВЗВИИНЛЖА